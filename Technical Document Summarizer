class ModernButton(tk.Canvas):
    def __init__(self, parent, text="", command=None, icon="",
                 width=160, height=36, radius=8,
                 bg="#1A5C8A", fg="#FFFFFF", hover_bg="#0D3A5C",
                 font_size=10, **kwargs):
        super().__init__(parent, width=width, height=height,
                         bd=0, highlightthickness=0, **kwargs)
        self._command  = command
        self._orig_cmd = command
        self._bg       = bg
        self._hover    = hover_bg
        self._fg       = fg
        self._label    = f"{icon}  {text}" if icon else text
        self._r        = radius
        self._bw       = width
        self._bh       = height
        self._fs       = font_size
        self._drawn    = False
        # Draw only after widget is mapped (works on Windows)
        self.bind("<Map>",      lambda e: self._first_draw())
        self.bind("<Enter>",    lambda e: self._safe_draw(hover_bg))
        self.bind("<Leave>",    lambda e: self._safe_draw(bg))
        self.bind("<Button-1>", lambda e: self._command() if self._command else None)

    def _first_draw(self):
        if not self._drawn:
            self._drawn = True
            self._draw(self._bg)

    def _safe_draw(self, color):
        try:
            if self.winfo_exists():
                self._draw(color)
        except Exception:
            pass

    def _draw(self, color):
        try:
            if not self.winfo_exists():
                return
            self.delete("all")
            r, w, h = self._r, self._bw, self._bh
            for args in [
                (0,0,2*r,2*r,90,90),(w-2*r,0,w,2*r,0,90),
                (0,h-2*r,2*r,h,180,90),(w-2*r,h-2*r,w,h,270,90)
            ]:
                self.create_arc(*args[:4], start=args[4], extent=args[5],
                                fill=color, outline=color)
            self.create_rectangle(r,0,w-r,h, fill=color, outline=color)
            self.create_rectangle(0,r,w,h-r, fill=color, outline=color)
            self.create_text(w//2, h//2, text=self._label, fill=self._fg,
                             font=("Segoe UI", self._fs, "bold"))
        except Exception:
            pass

    def set_state(self, state):
        if state == "disabled":
            self._safe_draw("#888888")
            self._command = None
        else:
            self._safe_draw(self._bg)
            self._command = self._orig_cmd

    def set_command(self, cmd):
        self._orig_cmd = cmd
        self._command  = cmd
        self._command = cmd


class MetricCard(tk.Frame):
    def __init__(self, parent, label="", value="—", theme=LIGHT, **kwargs):
        super().__init__(parent, bg=theme["metric_bg"],
                         relief="flat", bd=0, padx=10, pady=6, **kwargs)
        tk.Label(self, text=label, bg=theme["metric_bg"],
                 fg=theme["subtext"], font=("Segoe UI", 8)).pack(anchor="w")
        self._val = tk.Label(self, text=value, bg=theme["metric_bg"],
                             fg=theme["metric_val"],
                             font=("Segoe UI", 13, "bold"))
        self._val.pack(anchor="w")

    def update_value(self, v):
        self._val.config(text=str(v))

    def update_theme(self, theme):
        self.configure(bg=theme["metric_bg"])
        for w in self.winfo_children():
            if isinstance(w, tk.Label):
                w.configure(bg=theme["metric_bg"])
        self._val.configure(fg=theme["metric_val"])


