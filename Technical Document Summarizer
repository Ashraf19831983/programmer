                 font=("Segoe UI",10)).pack(padx=12, pady=(12,4), anchor="w")
        tb = tk.Text(win, font=("Segoe UI",10), wrap="word", padx=8, pady=6)
        tb.pack(fill="both", expand=True, padx=12, pady=4)

        def apply():
            t = tb.get("1.0","end").strip()
            if t:
                self._set_original(t)
                self.current_file = ""
                self.file_label.config(text="(Pasted text)")
                self._set_status(f"Text loaded ({len(t):,} chars)")
            win.destroy()

        ModernButton(win, text="Use this text", icon="✅",
                     command=apply, width=190, height=36).pack(pady=8)

    def _set_original(self, text: str):
        self.original_txt = text
        self.orig_text.config(state="normal")
        self.orig_text.delete("1.0","end")
        self.orig_text.insert("1.0", text)
        self._update_wc()

    # ──────────────────────────────────────────────────────────
    #  SUMMARIZATION
    # ──────────────────────────────────────────────────────────

    def _run_summarization(self):
        if self.is_running:
            return
        text = self.orig_text.get("1.0","end").strip()
        if not text:
            messagebox.showwarning("No Text", "Please import or paste text first.\nالرجاء إدخال نص أولاً.")
            return
        self.is_running = True
        self.run_btn.set_state("disabled")
        self._set_status("⏳ Processing …")
        self.progress_var.set(0)
        threading.Thread(target=self._do_summarize, args=(text,), daemon=True).start()

    def _do_summarize(self, text: str):
        try:
            lang = self.lang_var.get()
            if lang == "auto":
                lang = TextProcessor.detect_language(text)
            ratio = self.ratio_var.get()

            if self.compare_var.get():
                self._run_compare_all(text, lang, ratio)
            else:
                algo_name = self.algo_var.get()
                fn = ALGORITHMS[algo_name]
                self.after(0, lambda: self.progress_var.set(30))
                summary, stats = fn(text, ratio, lang)
                self.after(0, lambda: self.progress_var.set(70))
                metrics = self.calc.compute_all(text, summary,
                                                stats["processing_time"], lang, algo_name)
                self.after(0, lambda: self.progress_var.set(90))
                self.summary_txt  = summary
                self.metrics_data = metrics
                self.after(0, self._update_ui, summary, metrics)
        except Exception as e:
            self.after(0, lambda: messagebox.showerror("Error", str(e)))
        finally:
            self.after(0, self._finish_run)

    def _run_compare_all(self, text: str, lang: str, ratio: float):
        results = []
        n = len(ALGORITHMS)
        self._compare_data = {}
        for i, (name, fn) in enumerate(ALGORITHMS.items()):
            self.after(0, lambda v=int((i/n)*80)+10: self.progress_var.set(v))
            summary, stats = fn(text, ratio, lang)
            metrics = self.calc.compute_all(text, summary,
                                            stats["processing_time"], lang, name)
            results.append((name, summary, metrics))
            self._compare_data[name] = summary

        self.after(0, self._populate_compare_tab, results)
        # show best result (highest ROUGE-L) in editor
        best = max(results, key=lambda x: x[2]["rouge_l"]["f1"])
        self.summary_txt  = best[1]
        self.metrics_data = best[2]
        self.after(0, self._update_ui, best[1], best[2])
        self.after(0, lambda: self.notebook.select(self.compare_tab))

    def _populate_compare_tab(self, results):
        for row in self.compare_tree.get_children():
            self.compare_tree.delete(row)

        best_score, best_name = -1, ""
        for name, summary, m in results:
            r1 = m["rouge_1"]["f1"]
            r2 = m["rouge_2"]["f1"]
            rl = m["rouge_l"]["f1"]
            tc = m["topic_coverage"]
            kf = m["key_fact_retention"]
            comp = m["word_compression"]
            ms   = round(m["processing_time"]*1000, 1)
            wds  = m["summary_words"]
            score = r1*0.3 + r2*0.2 + rl*0.1 + tc*0.25 + kf*0.15
            if score > best_score:
                best_score, best_name = score, name
            self.compare_tree.insert("", "end", values=(
                name, f"{r1:.4f}", f"{r2:.4f}", f"{rl:.4f}",
                f"{tc:.4f}", f"{kf:.4f}", f"{comp:.1f}%", f"{ms}ms", wds),
                tags=(name,))

        # Color rows
        for name, col in ALGO_COLORS.items():
            self.compare_tree.tag_configure(name, foreground=col)

        # Winner
        best_m = next(m for n,s,m in results if n==best_name)
        self.winner_label.config(text=f"🏆  {best_name}")
        detail = (f"ROUGE-1: {best_m['rouge_1']['f1']:.4f}  |  "
                  f"ROUGE-2: {best_m['rouge_2']['f1']:.4f}  |  "
                  f"ROUGE-L: {best_m['rouge_l']['f1']:.4f}  |  "
                  f"Topic Coverage: {best_m['topic_coverage']:.4f}  |  "
                  f"Key-Fact Retention: {best_m['key_fact_retention']:.4f}  |  "
                  f"Compression: {best_m['word_compression']:.1f}%  |  "
                  f"Time: {best_m['processing_time']*1000:.1f}ms")
        self.winner_detail.config(text=detail)

    def _show_compare_summary(self, event=None):
        sel = self.compare_tree.selection()
        if not sel:
            return
        name = self.compare_tree.item(sel[0])["values"][0]
        txt  = self._compare_data.get(name, "")
        self.compare_summ.config(state="normal")
        self.compare_summ.delete("1.0","end")
        self.compare_summ.insert("1.0", txt)
        self.compare_summ.config(state="disabled")

    def _sort_tree(self, col):
        items = [(self.compare_tree.set(k, col), k)
                 for k in self.compare_tree.get_children('')]
        try:
            items.sort(key=lambda x: float(x[0].replace('%','').replace('ms','')),
                       reverse=True)
        except:
            items.sort(reverse=False)
        for idx, (_, k) in enumerate(items):
            self.compare_tree.move(k, '', idx)

    # ──────────────────────────────────────────────────────────
    #  UPDATE UI
    # ──────────────────────────────────────────────────────────

    def _update_ui(self, summary: str, metrics: dict):
        # Summary text
        self.summ_text.config(state="normal")
        self.summ_text.delete("1.0","end")
        self.summ_text.insert("1.0", summary)
        self.summ_text.config(state="disabled")

        r1 = metrics.get("rouge_1",{})
        r2 = metrics.get("rouge_2",{})
        rl = metrics.get("rouge_l",{})

        for key, val in [
            ("r1f", f"{r1.get('f1',0):.4f}"),
            ("r2f", f"{r2.get('f1',0):.4f}"),
            ("rlf", f"{rl.get('f1',0):.4f}"),
            ("r1p", f"{r1.get('precision',0):.4f}"),
            ("r1r", f"{r1.get('recall',0):.4f}"),
            ("r2p", f"{r2.get('precision',0):.4f}"),
        ]:
            if key in self.rouge_cards:
                self.rouge_cards[key].update_value(val)

        for key, val in [
            ("tc",  f"{metrics.get('topic_coverage',0):.4f}"),
            ("kfr", f"{metrics.get('key_fact_retention',0):.4f}"),
            ("ldo", f"{metrics.get('lexical_diversity_orig',0):.4f}"),
            ("lds", f"{metrics.get('lexical_diversity_summ',0):.4f}"),
        ]:
            if key in self.sem_cards:
                self.sem_cards[key].update_value(val)

        for key, val in [
            ("wcomp", f"{metrics.get('word_compression',0):.1f}%"),
            ("scomp", f"{metrics.get('sentence_compression',0):.1f}%"),
            ("owds",  metrics.get("original_words",0)),
            ("swds",  metrics.get("summary_words",0)),
            ("osnt",  metrics.get("original_sentences",0)),
            ("ssnt",  metrics.get("summary_sentences",0)),
        ]:
            if key in self.stat_cards:
                self.stat_cards[key].update_value(val)

        for key, val in [
            ("algo", metrics.get("algorithm","—")),
            ("lang", metrics.get("language","—")),
            ("time", f"{metrics.get('processing_time',0)*1000:.1f}ms"),
            ("och",  f"{metrics.get('original_chars',0):,}"),
            ("sch",  f"{metrics.get('summary_chars',0):,}"),
        ]:
            if key in self.perf_cards:
                self.perf_cards[key].update_value(val)

        rl_f1 = rl.get("f1", 0)
        self.quality_bar["value"] = rl_f1
        color = "#27AE60" if rl_f1 > 0.4 else "#E67E22" if rl_f1 > 0.2 else "#E74C3C"
        self.quality_pct.config(text=f"{rl_f1*100:.1f}%", fg=color)

        self.raw_text.config(state="normal")
        self.raw_text.delete("1.0","end")
        self.raw_text.insert("1.0", json.dumps(metrics, indent=2, ensure_ascii=False))
        self.raw_text.config(state="disabled")

        # History
        fname = os.path.basename(self.current_file) if self.current_file else "text"
        algo  = metrics.get("algorithm","?")
        entry = f"{fname} → {algo} (R-L:{rl_f1:.3f})"
        self.history.append((self.original_txt, summary, metrics))
        self.history_list.insert("end", entry)
        self.history_list.see("end")

        self._set_status(f"✅ Done  |  {algo}  |  ROUGE-L: {rl_f1:.4f}  |  "
                         f"Compression: {metrics.get('word_compression',0):.1f}%")

    def _finish_run(self):
        self.is_running = False
        self.run_btn.set_state("normal")
        self.run_btn.set_command(self._run_summarization)
        self.progress_var.set(100)
        self.after(800, lambda: self.progress_var.set(0))

    # ──────────────────────────────────────────────────────────
    #  EXPORT
    # ──────────────────────────────────────────────────────────

    def _export(self, fmt: str):
        if not self.summary_txt:
            messagebox.showwarning("No Summary", "Run summarization first.")
            return
        ext   = ".docx" if fmt=="docx" else ".pdf"
        ftype = [("Word","*.docx")] if fmt=="docx" else [("PDF","*.pdf")]
        path  = filedialog.asksaveasfilename(defaultextension=ext,
                                              filetypes=ftype,
                                              initialfile=f"summary{ext}")
        if not path:
            return
        lang = self.lang_var.get()
        if lang == "auto":
            lang = TextProcessor.detect_language(self.summary_txt)
        self._set_status(f"Exporting {fmt.upper()} …")
        try:
            if fmt == "docx":
                self.doc_handler.export_docx(self.summary_txt, self.current_file,
                                              self.metrics_data, path, lang)
            else:
                self.doc_handler.export_pdf(self.summary_txt, self.current_file,
                                             self.metrics_data, path, lang)
            self._set_status(f"✅ Exported: {os.path.basename(path)}")
            messagebox.showinfo("Export Successful", f"Saved:\n{path}")
        except Exception as e:
            messagebox.showerror("Export Error", str(e))
            self._set_status("Export failed")

    # ──────────────────────────────────────────────────────────
    #  THEME
    # ──────────────────────────────────────────────────────────

    def _apply_theme(self):
        t = self.theme
        self.configure(bg=t["bg"])
        self.header.configure(bg=t["header_bg"])
        self._tcolor(self.header, t, is_header=True)
        self.sidebar.configure(bg=t["sidebar"])
        self.sb_inner.configure(bg=t["sidebar"])
        self._tcolor(self.sb_inner, t, is_sidebar=True)
        self.main.configure(bg=t["bg"])
        for tab in [self.editor_tab, self.metrics_tab, self.compare_tab]:
            tab.configure(bg=t["bg"])
            self._tcolor(tab, t)
        for tb in [self.orig_text, self.summ_text]:
            tb.configure(bg=t["input_bg"], fg=t["text"],
                         insertbackground=t["text"], selectbackground=t["highlight"])
        self.statusbar.configure(bg=t["header_bg"])
        for w in self.statusbar.winfo_children():
            try:
                w.configure(bg=t["header_bg"], fg=t["header_txt"])
            except:
                pass
        style = ttk.Style()
        style.theme_use("clam")
        style.configure("TNotebook", background=t["bg"], borderwidth=0)
        style.configure("TNotebook.Tab", background=t["card"],
                        foreground=t["text"], padding=[12,4])
        style.map("TNotebook.Tab",
                  background=[("selected", t["primary"])],
                  foreground=[("selected","#FFFFFF")])
        style.configure("Treeview", background=t["card"],
                        foreground=t["text"], fieldbackground=t["card"])
        style.configure("Treeview.Heading",
                        background=t["primary"], foreground="#FFFFFF")

    def _tcolor(self, widget, t, is_sidebar=False, is_header=False):
        for w in widget.winfo_children():
            try:
                cls = w.winfo_class()
                bg = t["sidebar"] if is_sidebar else (t["header_bg"] if is_header else t["bg"])
                fg = t["sidebar_txt"] if (is_sidebar or is_header) else t["text"]
                if cls in ("Frame","Labelframe"):
                    w.configure(bg=bg)
                elif cls == "Label":
                    w.configure(bg=bg, fg=fg)
                elif cls in ("Checkbutton","Radiobutton"):
                    w.configure(bg=bg, fg=fg, selectcolor=bg, activebackground=bg)
                elif cls == "Button":
                    if is_sidebar or is_header:
                        w.configure(bg=bg, fg=fg, activebackground=t["primary"],
                                    activeforeground="#FFF")
                    else:
                        w.configure(bg=t["card"], fg=t["text"],
                                    activebackground=t["primary"],
                                    activeforeground="#FFF",
                                    highlightbackground=t["card_bdr"])
                elif cls == "Listbox":
                    w.configure(bg=t["input_bg"], fg=t["text"],
                                selectbackground=t["highlight"])
                elif cls == "Text":
                    w.configure(bg=t["input_bg"], fg=t["text"])
            except:
                pass
            self._tcolor(w, t, is_sidebar, is_header)

    def _toggle_theme(self):
        self.dark_mode = not self.dark_mode
        self.theme = DARK if self.dark_mode else LIGHT
        self.dark_btn.config(text="☀️ Light" if self.dark_mode else "🌙 Dark")
        self._apply_theme()

    # ──────────────────────────────────────────────────────────
    #  MISC
    # ──────────────────────────────────────────────────────────

    def _clear_all(self):
        self.orig_text.delete("1.0","end")
        self.summ_text.config(state="normal")
        self.summ_text.delete("1.0","end")
        self.summ_text.config(state="disabled")
        self.original_txt = self.summary_txt = ""
        self.metrics_data = {}
        self.current_file = ""
        self.file_label.config(text="No file selected")
        for cards in [self.rouge_cards, self.sem_cards, self.stat_cards, self.perf_cards]:
            for c in cards.values():
                c.update_value("—")
        self.quality_bar["value"] = 0
        self.quality_pct.config(text="0.0%")
        self._set_status("Cleared  |  تم المسح")

    def _load_history(self, event=None):
        sel = self.history_list.curselection()
        if not sel or sel[0] >= len(self.history):
            return
        orig, summ, met = self.history[sel[0]]
        self._set_original(orig)
        self._update_ui(summ, met)

    def _update_wc(self, event=None):
        wc = len(self.orig_text.get("1.0","end").split())
        self.wc_var.set(f"{wc:,} words")

    def _set_status(self, msg: str):
        self.status_var.set(msg)

