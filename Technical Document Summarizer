    def _import_file(self):
        path = filedialog.askopenfilename(
            title="Open Document",
            filetypes=[("Supported","*.docx *.pdf *.txt"),
                       ("Word","*.docx"),("PDF","*.pdf"),("Text","*.txt")])
        if not path:
            return
        self._set_status(f"Loading: {os.path.basename(path)} …")
        self.current_file = path
        try:
            ext = os.path.splitext(path)[1].lower()
            if ext == ".pdf":
                text = self.doc_handler.read_pdf(path)
            elif ext == ".docx":
                text = self.doc_handler.read_docx(path)
            else:
                with open(path, "r", encoding="utf-8", errors="replace") as f:
                    text = f.read()
            self._set_original(text)
            self.file_label.config(text=f"📎 {os.path.basename(path)}")
            self._set_status(f"Loaded: {os.path.basename(path)} ({len(text):,} chars)")
        except Exception as e:
            messagebox.showerror("Import Error", str(e))
            self._set_status("Import failed")

