class TextProcessor:
    ARABIC_STOP = set([
        'من','في','على','إلى','عن','مع','هذا','هذه','التي','الذي','أن','كل',
        'كما','مثل','بعد','قبل','حتى','لأن','وهو','وهي','ما','هو','هي','لا',
        'ولا','أو','بما','بين','وقد','مما','قد','لم','لن','منذ','حول','خلال',
        'ذلك','تلك','هؤلاء','الذين','اللتي','ومن','وفي','وعلى','وإلى','وعن',
        'وهذا','وهذه','وكان','وكانت','وتم','ويتم','وقال','وأضاف','وأشار',
    ])
    ENGLISH_STOP = set([
        'the','a','an','and','or','but','in','on','at','to','for','of','with',
        'by','from','up','about','into','through','is','are','was','were','be',
        'been','being','have','has','had','do','does','did','will','would',
        'could','should','may','might','must','can','that','this','these',
        'those','it','its','they','them','their','we','our','us','you','your',
        'he','she','his','her','i','my','me','which','who','whom','what',
        'when','where','how','not','no','nor','so','yet','both','either',
        'also','just','than','then','too','very','such','if','as','more',
    ])

    @staticmethod
    def detect_language(text: str) -> str:
        arabic_chars = len(re.findall(r'[\u0600-\u06FF]', text))
        return "arabic" if arabic_chars > len(text) * 0.2 else "english"

    @staticmethod
    def normalize_arabic(text: str) -> str:
        text = re.sub(r'[إأآا]', 'ا', text)
        text = re.sub(r'ى', 'ي', text)
        text = re.sub(r'ة', 'ه', text)
        text = re.sub(r'\u0640', '', text)   # tatweel
        text = re.sub(r'[\u064B-\u065F]', '', text)  # harakat
        return text

    @classmethod
    def tokenize(cls, text: str, lang: str) -> List[str]:
        if lang == "arabic":
            text = cls.normalize_arabic(text)
            tokens = re.findall(r'[\u0600-\u06FF]+', text)
            stop = cls.ARABIC_STOP
        else:
            tokens = re.findall(r'\b[a-zA-Z]+\b', text.lower())
            stop = cls.ENGLISH_STOP
        return [t for t in tokens if t not in stop and len(t) > 2]

    @staticmethod
    def split_sentences(text: str) -> List[str]:
        parts = re.split(r'(?<=[.!?؟])\s+|\n{2,}', text.strip())
        return [s.strip() for s in parts if len(s.strip()) > 20]


class Algorithms:
    @staticmethod
    def tfidf(text: str, ratio: float, lang: str) -> Tuple[str, dict]:
        t0 = time.perf_counter()
        sentences = TextProcessor.split_sentences(text)
        if len(sentences) < 3:
            return text, {"processing_time": time.perf_counter()-t0}
        try:
            pat = r'[\u0600-\u06FF]+' if lang=="arabic" else r'(?u)\b\w+\b'
            vec = TfidfVectorizer(max_features=2000, token_pattern=pat)
            mat = vec.fit_transform(sentences).toarray()
            scores = mat.mean(axis=1)
            n = max(2, int(len(sentences) * ratio))
            idx = sorted(np.argsort(scores)[-n:])
            summary = ' '.join(sentences[i] for i in idx)
        except Exception as e:
            summary = sentences[0] if sentences else text
        return summary, {"processing_time": time.perf_counter()-t0}

    @staticmethod
    def textrank(text: str, ratio: float, lang: str) -> Tuple[str, dict]:
        t0 = time.perf_counter()
        sentences = TextProcessor.split_sentences(text)
        if len(sentences) < 3:
            return text, {"processing_time": time.perf_counter()-t0}
        try:
            pat = r'[\u0600-\u06FF]+' if lang=="arabic" else r'(?u)\b\w+\b'
            vec = TfidfVectorizer(max_features=2000, token_pattern=pat)
            mat = vec.fit_transform(sentences).toarray()
            sim  = cosine_similarity(mat)
            np.fill_diagonal(sim, 0)
            G = nx.from_numpy_array(sim)
            pr = nx.pagerank(G, max_iter=200, tol=1e-4)
            scores = np.array([pr[i] for i in range(len(sentences))])
            n = max(2, int(len(sentences) * ratio))
            idx = sorted(np.argsort(scores)[-n:])
            summary = ' '.join(sentences[i] for i in idx)
        except Exception as e:
            summary = sentences[0] if sentences else text
        return summary, {"processing_time": time.perf_counter()-t0}

    @staticmethod
    def lsa(text: str, ratio: float, lang: str) -> Tuple[str, dict]:
        t0 = time.perf_counter()
        sentences = TextProcessor.split_sentences(text)
        if len(sentences) < 3:
            return text, {"processing_time": time.perf_counter()-t0}
        try:
            pat = r'[\u0600-\u06FF]+' if lang=="arabic" else r'(?u)\b\w+\b'
            vec = TfidfVectorizer(max_features=2000, token_pattern=pat)
            mat = vec.fit_transform(sentences).toarray()
            n_comp = min(10, len(sentences)-1, mat.shape[1]-1)
            if n_comp < 1:
                return sentences[0], {"processing_time": time.perf_counter()-t0}
            svd = TruncatedSVD(n_components=n_comp, random_state=42)
            reduced = svd.fit_transform(mat)
            scores = np.sqrt((reduced**2).sum(axis=1))
            n = max(2, int(len(sentences) * ratio))
            idx = sorted(np.argsort(scores)[-n:])
            summary = ' '.join(sentences[i] for i in idx)
        except Exception as e:
            summary = sentences[0] if sentences else text
        return summary, {"processing_time": time.perf_counter()-t0}

    @staticmethod
    def frequency(text: str, ratio: float, lang: str) -> Tuple[str, dict]:
        t0 = time.perf_counter()
        sentences = TextProcessor.split_sentences(text)
        if len(sentences) < 3:
            return text, {"processing_time": time.perf_counter()-t0}
        all_tok = TextProcessor.tokenize(text, lang)
        freq = Counter(all_tok)
        maxf = max(freq.values(), default=1)
        freq_n = {w: v/maxf for w, v in freq.items()}
        scores = []
        for s in sentences:
            toks = TextProcessor.tokenize(s, lang)
            sc = sum(freq_n.get(t, 0) for t in toks) / max(len(toks), 1)
            scores.append(sc)
        scores = np.array(scores)
        n = max(2, int(len(sentences) * ratio))
        idx = sorted(np.argsort(scores)[-n:])
        summary = ' '.join(sentences[i] for i in idx)
        return summary, {"processing_time": time.perf_counter()-t0}


