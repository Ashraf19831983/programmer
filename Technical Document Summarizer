class MetricsCalculator:
    @staticmethod
    def _ngrams(tokens, n):
        return Counter(tuple(tokens[i:i+n]) for i in range(len(tokens)-n+1))

    @classmethod
    def rouge_n(cls, hyp, ref, n):
        h, r = cls._ngrams(hyp, n), cls._ngrams(ref, n)
        ov = sum((h & r).values())
        p = ov / max(sum(h.values()), 1)
        rc = ov / max(sum(r.values()), 1)
        f1 = 2*p*rc / max(p+rc, 1e-9)
        return {"precision": round(p,4), "recall": round(rc,4), "f1": round(f1,4)}

    @staticmethod
    def rouge_l(hyp, ref):
        m, n = len(hyp), len(ref)
        dp = [[0]*(n+1) for _ in range(m+1)]
        for i in range(1, m+1):
            for j in range(1, n+1):
                dp[i][j] = dp[i-1][j-1]+1 if hyp[i-1]==ref[j-1] else max(dp[i-1][j],dp[i][j-1])
        lcs = dp[m][n]
        p = lcs / max(m, 1)
        rc = lcs / max(n, 1)
        f1 = 2*p*rc / max(p+rc, 1e-9)
        return {"precision": round(p,4), "recall": round(rc,4), "f1": round(f1,4)}

    @staticmethod
    def lexical_diversity(tokens):
        return round(len(set(tokens)) / max(len(tokens), 1), 4)

    @staticmethod
    def topic_coverage(orig_sents, summ_sents, lang):
        all_s = orig_sents + summ_sents
        if len(all_s) < 2 or not ENGINE_OK:
            return 0.0
        try:
            pat = r'[\u0600-\u06FF]+' if lang=="arabic" else r'(?u)\b\w+\b'
            vec = TfidfVectorizer(max_features=500, token_pattern=pat)
            mat = vec.fit_transform(all_s).toarray()
            n = len(orig_sents)
            sim = cosine_similarity(mat[n:], mat[:n])
            covered = np.max(sim, axis=0)
            return round(float(np.mean(covered > 0.15)), 4)
        except:
            return 0.0

    @staticmethod
    def key_fact_retention(orig_tok, summ_tok):
        freq = Counter(orig_tok)
        top30 = set(w for w, _ in freq.most_common(30))
        return round(len(top30 & set(summ_tok)) / max(len(top30), 1), 4)

    def compute_all(self, original: str, summary: str, proc_time: float,
                    lang: str, algo_name: str = "") -> dict:
        orig_tok  = TextProcessor.tokenize(original, lang)
        summ_tok  = TextProcessor.tokenize(summary, lang)
        orig_sent = TextProcessor.split_sentences(original)
        summ_sent = TextProcessor.split_sentences(summary)

        r1 = self.rouge_n(summ_tok, orig_tok, 1)
        r2 = self.rouge_n(summ_tok, orig_tok, 2)
        rl = self.rouge_l(summ_tok, orig_tok)

        word_comp = (1 - len(summ_tok)/max(len(orig_tok),1)) * 100
        sent_comp = (1 - len(summ_sent)/max(len(orig_sent),1)) * 100
        tc  = self.topic_coverage(orig_sent, summ_sent, lang)
        kfr = self.key_fact_retention(orig_tok, summ_tok)

        return {
            "algorithm":              algo_name,
            "language":               lang,
            "processing_time":        round(proc_time, 5),
            "rouge_1":                r1,
            "rouge_2":                r2,
            "rouge_l":                rl,
            "topic_coverage":         tc,
            "key_fact_retention":     kfr,
            "word_compression":       round(word_comp, 2),
            "sentence_compression":   round(sent_comp, 2),
            "lexical_diversity_orig": self.lexical_diversity(orig_tok),
            "lexical_diversity_summ": self.lexical_diversity(summ_tok),
            "original_sentences":     len(orig_sent),
            "summary_sentences":      len(summ_sent),
            "original_words":         len(orig_tok),
            "summary_words":          len(summ_tok),
            "original_chars":         len(original),
            "summary_chars":          len(summary),
        }


class DocumentHandler:
    def read_pdf(self, path: str) -> str:
        if not PDF_OK:
            raise ImportError("pdfplumber not installed. Run: pip install pdfplumber")
        import pdfplumber
        text = []
        with pdfplumber.open(path) as pdf:
            for page in pdf.pages:
                t = page.extract_text()
                if t:
                    text.append(t)
        return '\n\n'.join(text)

    def read_docx(self, path: str) -> str:
        if not DOCX_READ_OK:
            raise ImportError("python-docx not installed. Run: pip install python-docx")
        doc = DocxDocument(path)
        return '\n\n'.join(p.text for p in doc.paragraphs if p.text.strip())

    def export_docx(self, summary: str, source: str, metrics: dict, path: str, lang: str):
        if not DOCX_WRITE_OK:
            raise ImportError("python-docx not installed.")
        doc = DocxDoc()
        doc.add_heading("Document Summary  |  ملخص الوثيقة", 0)
        if source:
            doc.add_paragraph(f"Source: {os.path.basename(source)}")
        doc.add_heading("Summary  |  الملخص", 1)
        p = doc.add_paragraph(summary)
        if lang == "arabic":
            p.alignment = WD_ALIGN_PARAGRAPH.RIGHT
        doc.add_heading("Metrics  |  المقاييس", 1)
        r1 = metrics.get("rouge_1", {})
        r2 = metrics.get("rouge_2", {})
        rl = metrics.get("rouge_l", {})
        rows = [
            ("Algorithm", metrics.get("algorithm","—")),
            ("Language", metrics.get("language","—")),
            ("ROUGE-1 F1", f"{r1.get('f1',0):.4f}"),
            ("ROUGE-2 F1", f"{r2.get('f1',0):.4f}"),
            ("ROUGE-L F1", f"{rl.get('f1',0):.4f}"),
            ("Topic Coverage", f"{metrics.get('topic_coverage',0):.4f}"),
            ("Key-Fact Retention", f"{metrics.get('key_fact_retention',0):.4f}"),
            ("Word Compression", f"{metrics.get('word_compression',0):.1f}%"),
            ("Processing Time", f"{metrics.get('processing_time',0):.4f}s"),
        ]
        table = doc.add_table(rows=len(rows)+1, cols=2)
        table.style = "Table Grid"
        hdr = table.rows[0].cells
        hdr[0].text, hdr[1].text = "Metric", "Value"
        for i, (k, v) in enumerate(rows):
            table.rows[i+1].cells[0].text = k
            table.rows[i+1].cells[1].text = v
        doc.save(path)

    def export_pdf(self, summary: str, source: str, metrics: dict, path: str, lang: str):
        if not PDF_WRITE_OK:
            raise ImportError("reportlab not installed.")
        from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle
        from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
        from reportlab.lib.pagesizes import A4
        from reportlab.lib import colors as rl_colors
        from reportlab.lib.enums import TA_RIGHT, TA_LEFT

        doc = SimpleDocTemplate(path, pagesize=A4,
                                rightMargin=40, leftMargin=40,
                                topMargin=50, bottomMargin=40)
        styles = getSampleStyleSheet()
        story = []
        title_style = ParagraphStyle("title", fontSize=16, fontName="Helvetica-Bold",
                                     spaceAfter=12, textColor=rl_colors.HexColor("#1A5C8A"))
        body_style = ParagraphStyle("body", fontSize=11, fontName="Helvetica",
                                    leading=16, spaceAfter=8,
                                    alignment=TA_RIGHT if lang=="arabic" else TA_LEFT)
        story.append(Paragraph("Document Summary | ملخص الوثيقة", title_style))
        if source:
            story.append(Paragraph(f"Source: {os.path.basename(source)}", styles["Normal"]))
        story.append(Spacer(1, 12))
        story.append(Paragraph("Summary | الملخص", title_style))
        for para in summary.split('\n'):
            if para.strip():
                story.append(Paragraph(para.strip(), body_style))
        story.append(Spacer(1, 16))
        story.append(Paragraph("Metrics | المقاييس", title_style))
        r1 = metrics.get("rouge_1", {})
        r2 = metrics.get("rouge_2", {})
        rl = metrics.get("rouge_l", {})
        data = [["Metric", "Value"],
                ["Algorithm", str(metrics.get("algorithm","—"))],
                ["ROUGE-1 F1", f"{r1.get('f1',0):.4f}"],
                ["ROUGE-2 F1", f"{r2.get('f1',0):.4f}"],
                ["ROUGE-L F1", f"{rl.get('f1',0):.4f}"],
                ["Topic Coverage", f"{metrics.get('topic_coverage',0):.4f}"],
                ["Key-Fact Retention", f"{metrics.get('key_fact_retention',0):.4f}"],
                ["Word Compression", f"{metrics.get('word_compression',0):.1f}%"],
                ["Processing Time", f"{metrics.get('processing_time',0):.4f}s"]]
        t = Table(data, colWidths=[200, 200])
        t.setStyle(TableStyle([
            ("BACKGROUND", (0,0), (-1,0), rl_colors.HexColor("#1A5C8A")),
            ("TEXTCOLOR",  (0,0), (-1,0), rl_colors.white),
            ("FONTNAME",   (0,0), (-1,0), "Helvetica-Bold"),
            ("BACKGROUND", (0,1), (-1,-1), rl_colors.HexColor("#EBF5FB")),
            ("ROWBACKGROUNDS", (0,1), (-1,-1),
             [rl_colors.HexColor("#EBF5FB"), rl_colors.white]),
            ("GRID", (0,0), (-1,-1), 0.5, rl_colors.HexColor("#C8D0DA")),
            ("FONTSIZE", (0,0), (-1,-1), 10),
            ("PADDING", (0,0), (-1,-1), 6),
        ]))
        story.append(t)
        doc.build(story)


